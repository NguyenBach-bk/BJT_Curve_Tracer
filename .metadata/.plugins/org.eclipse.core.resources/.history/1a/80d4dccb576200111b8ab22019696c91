/**
 * @brief The application entry point.
 * @retval int
 */
int
main(void)
{
  /* USER CODE BEGIN 1 */
  /* USER CODE END 1 */

  HAL_Init();
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */
  /* USER CODE END SysInit */

  MX_GPIO_Init();
  MX_ADC1_Init();
  MX_DAC_Init();
  MX_SPI2_Init();
  MX_TIM2_Init();
  MX_TIM4_Init();
  MX_TIM6_Init();
  MX_USB_DEVICE_Init();

  /* USER CODE BEGIN 2 */
  HAL_TIM_Base_Start(&htim6);
  HAL_DAC_Start(&hdac, DAC_CHANNEL_1);
  HAL_DAC_Start(&hdac, DAC_CHANNEL_2);
  ILI9341_Init();
  HAL_TIM_Encoder_Start(&htim4, TIM_CHANNEL_ALL);
  last_encoder_val = __HAL_TIM_GET_COUNTER(&htim4);
  // Không start TIM2 ngay, sẽ start khi vào STATE_SET_BATCH_COUNT
  Draw_Menu_UI();
  /* USER CODE END 2 */

  while (1) {
    /* USER CODE BEGIN WHILE */
    uint16_t current_encoder_val = __HAL_TIM_GET_COUNTER(&htim4);
    int16_t delta = (int16_t)(current_encoder_val - last_encoder_val);

    if (abs(delta) >= 4) {
      if (current_state == STATE_MENU) {
        int old_menu_index = menu_index;
        if (delta > 0) menu_index++;
        else menu_index--;
        if (menu_index < 0) menu_index = 0;
        if (menu_index > 5) menu_index = 5; // có 6 mục (0..5)
        last_encoder_val = current_encoder_val;
        if (old_menu_index != menu_index) {
          Draw_Menu_Line(old_menu_index, 0);
          Draw_Menu_Line(menu_index, 1);
        }
      } else if (current_state == STATE_PROMPT_SAVE) {
        prompt_selection = !prompt_selection;
        last_encoder_val = current_encoder_val;
        Draw_Prompt_Save_Buttons(prompt_selection);
      } else if (current_state == STATE_SET_BATCH_COUNT) {
        // Xử lý encoder TIM2 để nhập số lượng
        uint16_t enc_val = __HAL_TIM_GET_COUNTER(&htim2);
        int16_t delta2 = (int16_t)(enc_val - last_encoder_val_batch);
        if (abs(delta2) >= 2) {
          if (delta2 > 0) batch_count++;
          else batch_count--;
          if (batch_count < 1) batch_count = 1;
          if (batch_count > MAX_BATCH_SIZE) batch_count = MAX_BATCH_SIZE;
          last_encoder_val_batch = enc_val;
          // Cập nhật hiển thị
          ILI9341_FillRectangle(100, 130, 200, 40, ILI9341_BLACK);
          char buf[16];
          sprintf(buf, "Count: %d", batch_count);
          ILI9341_WriteString(100, 130, buf, Font_16x26, ILI9341_YELLOW, ILI9341_BLACK);
        }
      } else {
        last_encoder_val = current_encoder_val;
      }
    }

    // Xử lý nút nhấn (PC0)
    if (HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_0) == GPIO_PIN_RESET) {
      HAL_Delay(50);
      if (HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_0) == GPIO_PIN_RESET) {
        switch (current_state) {
          case STATE_MENU:
            if (menu_index == 0) cfg_is_pnp = !cfg_is_pnp;
            else if (menu_index == 1) {
              if (cfg_max_ib_uA == 50) cfg_max_ib_uA = 75;
              else if (cfg_max_ib_uA == 75) cfg_max_ib_uA = 100;
              else if (cfg_max_ib_uA == 100) cfg_max_ib_uA = 150;
              else if (cfg_max_ib_uA == 150) cfg_max_ib_uA = 250;
              else if (cfg_max_ib_uA == 250) cfg_max_ib_uA = 350;
              else if (cfg_max_ib_uA == 350) cfg_max_ib_uA = 500;
              else cfg_max_ib_uA = 50;
            } else if (menu_index == 2) {
              if (cfg_num_steps == 3) cfg_num_steps = 5;
              else if (cfg_num_steps == 5) cfg_num_steps = 7;
              else if (cfg_num_steps == 7) cfg_num_steps = 10;
              else cfg_num_steps = 3;
            } else if (menu_index == 3) {
              if (cfg_max_power == 0.1f) cfg_max_power = 0.25f;
              else if (cfg_max_power == 0.25f) cfg_max_power = 0.35f;
              else if (cfg_max_power == 0.35f) cfg_max_power = 0.5f;
              else cfg_max_power = 0.1f;
            } else if (menu_index == 4) {
              // START SCAN
              current_state = STATE_SCANNING;
              ILI9341_FillScreen(ILI9341_BLACK);
              ILI9341_WriteString(110, 110, "Scanning...", Font_11x18, ILI9341_YELLOW, ILI9341_BLACK);
              Measure_BJT(cfg_is_pnp, cfg_max_ib_uA, cfg_num_steps, 1);
              Draw_Graph(cfg_is_pnp, cfg_max_ib_uA, cfg_num_steps, 0);
              current_state = STATE_SHOW_GRAPH;
            } else if (menu_index == 5) {
              // BATCH TEST
              current_state = STATE_SET_BATCH_COUNT;
              // Khởi tạo TIM2 encoder
              HAL_TIM_Encoder_Start(&htim2, TIM_CHANNEL_ALL);
              __HAL_TIM_SET_COUNTER(&htim2, 0);
              last_encoder_val_batch = 0;
              batch_count = 1;
              // Vẽ màn hình nhập số
              ILI9341_FillScreen(ILI9341_BLACK);
              ILI9341_WriteString(40, 80, "Enter batch size (1-20)", Font_11x18, ILI9341_CYAN, ILI9341_BLACK);
              char buf[16];
              sprintf(buf, "Count: %d", batch_count);
              ILI9341_WriteString(100, 130, buf, Font_16x26, ILI9341_YELLOW, ILI9341_BLACK);
              ILI9341_WriteString(80, 200, "Press button to confirm", Font_11x18, ILI9341_WHITE, ILI9341_BLACK);
            }
            if (current_state == STATE_MENU) Draw_Menu_Line(menu_index, 1);
            break;

          case STATE_SHOW_GRAPH:
            current_state = STATE_PROMPT_SAVE;
            prompt_selection = 0;
            Draw_Prompt_Save_BG();
            Draw_Prompt_Save_Buttons(prompt_selection);
            break;

          case STATE_PROMPT_SAVE:
            if (prompt_selection == 0) {
              current_state = STATE_MENU;
              Draw_Menu_UI();
            } else {
              current_state = STATE_WAIT_BJT2;
              Draw_Prompt_InsertBJT2();
            }
            break;

          case STATE_WAIT_BJT2:
            current_state = STATE_SCANNING;
            ILI9341_FillScreen(ILI9341_BLACK);
            ILI9341_WriteString(110, 110, "Scanning...", Font_11x18, ILI9341_YELLOW, ILI9341_BLACK);
            Measure_BJT(cfg_is_pnp, cfg_max_ib_uA, cfg_num_steps, 2);
            Draw_Graph(cfg_is_pnp, cfg_max_ib_uA, cfg_num_steps, 1);
            current_state = STATE_SHOW_COMPARE;
            break;

          case STATE_SHOW_COMPARE:
            current_state = STATE_MENU;
            Draw_Menu_UI();
            break;

          case STATE_SET_BATCH_COUNT:
            // Xác nhận số lượng, chuyển sang đo batch
            HAL_TIM_Encoder_Stop(&htim2);
            current_state = STATE_BATCH_SCANNING;
            batch_current = 0;
            ILI9341_FillScreen(ILI9341_BLACK);
            char msg[64];
            sprintf(msg, "Insert BJT #%d and press button", batch_current+1);
            ILI9341_WriteString(40, 80, msg, Font_11x18, ILI9341_YELLOW, ILI9341_BLACK);
            break;

          case STATE_BATCH_SCANNING:
            {
              // Đo BJT hiện tại
              float hfe, icmax;
              ILI9341_FillRectangle(40, 80, 240, 30, ILI9341_BLACK);
              ILI9341_WriteString(80, 80, "Measuring...", Font_11x18, ILI9341_GREEN, ILI9341_BLACK);
              Measure_BJT_For_Batch(cfg_is_pnp, cfg_max_ib_uA, cfg_num_steps, &hfe, &icmax);
              batch_hfe[batch_current] = hfe;
              batch_icmax[batch_current] = icmax;
              batch_current++;
              if (batch_current < batch_count) {
                char tmp[64];
                sprintf(tmp, "Insert BJT #%d and press button", batch_current+1);
                ILI9341_FillScreen(ILI9341_BLACK);
                ILI9341_WriteString(40, 80, tmp, Font_11x18, ILI9341_YELLOW, ILI9341_BLACK);
              } else {
                // Đã đo xong, chuyển sang thống kê
                current_state = STATE_BATCH_RESULT;
                // Tính mean
                float sum = 0;
                for (int i=0; i<batch_count; i++) sum += batch_hfe[i];
                batch_mean = sum / batch_count;
                // Tính std
                float var = 0;
                for (int i=0; i<batch_count; i++) {
                  float d = batch_hfe[i] - batch_mean;
                  var += d*d;
                }
                batch_std = sqrt(var / batch_count);
                float low = batch_mean - 3*batch_std;
                float high = batch_mean + 3*batch_std;
                batch_good_count = 0;
                int bad_idx = 0;
                for (int i=0; i<batch_count; i++) {
                  if (batch_hfe[i] >= low && batch_hfe[i] <= high) {
                    batch_good_count++;
                  } else {
                    batch_bad_indices[bad_idx++] = i+1;
                  }
                }
                // Hiển thị kết quả
                ILI9341_FillScreen(ILI9341_BLACK);
                char line[64];
                sprintf(line, "Batch of %d BJTs", batch_count);
                ILI9341_WriteString(20, 20, line, Font_11x18, ILI9341_WHITE, ILI9341_BLACK);
                sprintf(line, "Mean hFE = %.1f", batch_mean);
                ILI9341_WriteString(20, 50, line, Font_11x18, ILI9341_CYAN, ILI9341_BLACK);
                sprintf(line, "Std Dev = %.2f", batch_std);
                ILI9341_WriteString(20, 80, line, Font_11x18, ILI9341_CYAN, ILI9341_BLACK);
                sprintf(line, "3σ range: %.1f - %.1f", low, high);
                ILI9341_WriteString(20, 110, line, Font_11x18, ILI9341_YELLOW, ILI9341_BLACK);
                sprintf(line, "Good (within 3σ): %d", batch_good_count);
                ILI9341_WriteString(20, 140, line, Font_11x18, ILI9341_GREEN, ILI9341_BLACK);
                int outlier = batch_count - batch_good_count;
                sprintf(line, "Outliers: %d", outlier);
                ILI9341_WriteString(20, 170, line, Font_11x18, ILI9341_RED, ILI9341_BLACK);
                if (outlier > 0) {
                  char idx_str[64] = "Indices: ";
                  char num[8];
                  for (int k=0; k<bad_idx && k<5; k++) {
                    sprintf(num, "%d ", batch_bad_indices[k]);
                    strcat(idx_str, num);
                  }
                  if (bad_idx > 5) strcat(idx_str, "...");
                  ILI9341_WriteString(20, 200, idx_str, Font_7x10, ILI9341_RED, ILI9341_BLACK);
                }
                ILI9341_WriteString(40, 230, "Press button to menu", Font_7x10, ILI9341_WHITE, ILI9341_BLACK);
              }
            }
            break;

          case STATE_BATCH_RESULT:
            current_state = STATE_MENU;
            Draw_Menu_UI();
            break;

          default:
            break;
        }
        while (HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_0) == GPIO_PIN_RESET);
      }
    }
    /* USER CODE END WHILE */
  }
}

